# 8.  VISUALISATION SUITE
# ──────────────────────────────────────────────────────────────────────────────
def denorm(tensor):
    mean = torch.tensor([0.485, 0.456, 0.406])
    std  = torch.tensor([0.229, 0.224, 0.225])
    img  = tensor.cpu() * std[:, None, None] + mean[:, None, None]
    return img.permute(1, 2, 0).clamp(0, 1).numpy()


def plot_class_distribution(root: str, path: str):
    counts = {s: {c: 0 for c in CLASS_NAMES} for s in ["train", "val", "test"]}
    for split in counts:
        for cls in CLASS_NAMES:
            d = os.path.join(root, split, cls)
            if os.path.isdir(d):
                counts[split][cls] = len(os.listdir(d))

    x  = np.arange(len(CLASS_NAMES))
    w  = 0.25
    fig, ax = plt.subplots(figsize=(11, 5))
    colors  = ["#4C72B0", "#DD8452", "#55A868"]
    for i, (split, col) in enumerate(zip(["train", "val", "test"], colors)):
        vals = [counts[split][c] for c in CLASS_NAMES]
        ax.bar(x + i * w, vals, w, label=split.capitalize(), color=col)

    ax.set_xticks(x + w)
    ax.set_xticklabels(CLASS_NAMES, fontsize=11)
    ax.set_ylabel("Number of Images", fontsize=11)
    ax.set_title("Chest X-Ray Dataset — Class Distribution", fontsize=13, fontweight="bold")
    ax.legend(fontsize=10); ax.grid(axis="y", alpha=0.3)
    plt.tight_layout()
    plt.savefig(path, dpi=150, bbox_inches="tight")
    print(f"  [PLOT] Class distribution  → {path}")
    plt.close()


def plot_training_curves(h1, h2, path: str):
    fig, axes = plt.subplots(2, 2, figsize=(15, 10))
    fig.suptitle("ResNet50 Fine-Tuning — Medical X-Ray Classification\nTraining Curves",
                 fontsize=14, fontweight="bold")

    for col, (h, lbl) in enumerate([(h1, "Phase 1: Feature Extraction"),
                                     (h2, "Phase 2: Full Fine-Tuning")]):
        ep = range(1, len(h["train_loss"]) + 1)

        axes[0][col].plot(ep, h["train_loss"], "b-o", markersize=5, label="Train")
        axes[0][col].plot(ep, h["val_loss"],   "r-o", markersize=5, label="Val")
        axes[0][col].set_title(f"{lbl}\nFocal Loss")
        axes[0][col].set_xlabel("Epoch"); axes[0][col].set_ylabel("Loss")
        axes[0][col].legend(); axes[0][col].grid(alpha=0.3)

        axes[1][col].plot(ep, h["train_acc"], "b-o", markersize=5, label="Train")
        axes[1][col].plot(ep, h["val_acc"],   "r-o", markersize=5, label="Val")
        axes[1][col].set_title(f"{lbl}\nAccuracy")
        axes[1][col].set_xlabel("Epoch"); axes[1][col].set_ylabel("Accuracy")
        axes[1][col].set_ylim(0, 1); axes[1][col].legend(); axes[1][col].grid(alpha=0.3)

    plt.tight_layout()
    plt.savefig(path, dpi=150, bbox_inches="tight")
    print(f"  [PLOT] Training curves     → {path}")
    plt.close()


def plot_confusion_matrix(labels, preds, path: str):
    cm  = confusion_matrix(labels, preds)
    cm_norm = cm.astype(float) / cm.sum(axis=1, keepdims=True)

    fig, axes = plt.subplots(1, 2, figsize=(16, 6))
    fig.suptitle("Confusion Matrix — Test Set (ResNet50 Fine-Tuned)",
                 fontsize=13, fontweight="bold")

    for ax, data, title, fmt in [
        (axes[0], cm,      "Counts",       "d"),
        (axes[1], cm_norm, "Normalised",   ".2f"),
    ]:
        sns.heatmap(data, annot=True, fmt=fmt, cmap="Blues",
                    xticklabels=CLASS_NAMES, yticklabels=CLASS_NAMES, ax=ax,
                    linewidths=0.5, linecolor="gray")
        ax.set_title(title, fontsize=11)
        ax.set_xlabel("Predicted"); ax.set_ylabel("True")

    plt.tight_layout()
    plt.savefig(path, dpi=150, bbox_inches="tight")
    print(f"  [PLOT] Confusion matrix    → {path}")
    plt.close()


def plot_roc_curves(labels, probs, path: str):
    """Multi-class One-vs-Rest AUC-ROC curves — critical metric in medical AI."""
    labels_bin = label_binarize(labels, classes=range(NUM_CLASSES))
    colors = ["#4C72B0", "#DD8452", "#55A868", "#C44E52"]

    fig, ax = plt.subplots(figsize=(9, 7))
    aucs = []
    for i, (cls, col) in enumerate(zip(CLASS_NAMES, colors)):
        fpr, tpr, _ = roc_curve(labels_bin[:, i], probs[:, i])
        auc = roc_auc_score(labels_bin[:, i], probs[:, i])
        aucs.append(auc)
        ax.plot(fpr, tpr, color=col, lw=2, label=f"{cls}  (AUC = {auc:.3f})")

    ax.plot([0, 1], [0, 1], "k--", lw=1)
    ax.set_xlabel("False Positive Rate", fontsize=12)
    ax.set_ylabel("True Positive Rate",  fontsize=12)
    ax.set_title(f"AUC-ROC Curves — One-vs-Rest\n"
                 f"Mean AUC = {np.mean(aucs):.3f}",
                 fontsize=13, fontweight="bold")
    ax.legend(fontsize=11); ax.grid(alpha=0.3)
    plt.tight_layout()
    plt.savefig(path, dpi=150, bbox_inches="tight")
    print(f"  [PLOT] ROC curves          → {path}")
    plt.close()
    return dict(zip(CLASS_NAMES, aucs))


def plot_gradcam_grid(model, dataset, device, path: str, n: int = 8):
    """Grad-CAM heatmaps overlaid on X-ray images — explainability for clinicians."""
    model.eval()
    indices = random.sample(range(len(dataset)), min(n, len(dataset)))
    fig, axes = plt.subplots(2, n, figsize=(n * 2.2, 6))
    fig.suptitle("Grad-CAM Visualisations — Regions Driving Predictions\n"
                 "(Green border = Correct  |  Red border = Incorrect)",
                 fontsize=12, fontweight="bold")

    for col, idx in enumerate(indices):
        img_t, true_lbl = dataset[idx]
        with torch.no_grad():
            logits = model(img_t.unsqueeze(0).to(device))
            pred   = logits.argmax(1).item()
            conf   = F.softmax(logits, dim=1).max().item()

        cam  = generate_gradcam(model, img_t, pred, device)
        orig = denorm(img_t)

        # Original image
        axes[0][col].imshow(orig)
        correct = pred == true_lbl
        color   = "lime" if correct else "red"
        for spine in axes[0][col].spines.values():
            spine.set_edgecolor(color); spine.set_linewidth(3)
        axes[0][col].set_title(
            f"T:{CLASS_NAMES[true_lbl][:4]}\nP:{CLASS_NAMES[pred][:4]} {conf:.0%}",
            fontsize=7, color=color
        )
        axes[0][col].axis("off")

        # Grad-CAM overlay
        axes[1][col].imshow(orig)
        axes[1][col].imshow(cam, cmap="jet", alpha=0.45)
        axes[1][col].set_title("Grad-CAM", fontsize=7)
        axes[1][col].axis("off")

    plt.tight_layout()
    plt.savefig(path, dpi=150, bbox_inches="tight")
    print(f"  [PLOT] Grad-CAM grid       → {path}")
    plt.close()


def plot_per_class_sensitivity(labels, preds, path: str):
    """
    Sensitivity (Recall) per class bar chart.
    In medical AI, sensitivity = most critical metric
    (missing a disease is worse than a false alarm).
    """
    report = classification_report(labels, preds,
                                   target_names=CLASS_NAMES, output_dict=True)
    sens   = [report[c]["recall"] for c in CLASS_NAMES]
    precs  = [report[c]["precision"] for c in CLASS_NAMES]
    f1s    = [report[c]["f1-score"] for c in CLASS_NAMES]

    x    = np.arange(len(CLASS_NAMES))
    w    = 0.25
    fig, ax = plt.subplots(figsize=(10, 6))
    ax.bar(x - w, sens,  w, label="Sensitivity (Recall)", color="#55A868")
    ax.bar(x,     precs, w, label="Precision",             color="#4C72B0")
    ax.bar(x + w, f1s,   w, label="F1-Score",              color="#DD8452")

    ax.set_xticks(x); ax.set_xticklabels(CLASS_NAMES, fontsize=11)
    ax.set_ylim(0, 1.1)
    ax.axhline(0.9, color="red", ls="--", lw=1, label="Clinical threshold (0.90)")
    ax.set_ylabel("Score", fontsize=11)
    ax.set_title("Per-Class Performance Metrics\n(Sensitivity is Most Critical for Disease Detection)",
                 fontsize=12, fontweight="bold")
    ax.legend(fontsize=10); ax.grid(axis="y", alpha=0.3)
    plt.tight_layout()
    plt.savefig(path, dpi=150, bbox_inches="tight")
    print(f"  [PLOT] Sensitivity chart   → {path}")
    plt.close()


# ──────────────────────────────────────────────────────────────────────────────
# 9.  MAIN PIPELINE
# ──────────────────────────────────────────────────────────────────────────────
def main():
    # ── Hyper-parameters ──────────────────────────────────────────────────────
    BATCH_SIZE    = 32
    P1_EPOCHS     = 8   # Feature extraction
    P2_EPOCHS     = 12  # Full fine-tuning
    P1_LR         = 1e-3
    P2_LR         = 1e-4
    WEIGHT_DECAY  = 1e-4
    DROPOUT       = 0.5
    FOCAL_GAMMA   = 2.0

    # Reflects real-world clinical imbalance (Normal >> Disease)
    SAMPLES = {"Normal": 250, "Pneumonia": 180, "COVID-19": 150, "Tuberculosis": 120}

    # ── Generate synthetic data ───────────────────────────────────────────────
    if not os.path.exists(DATA_ROOT):
        generate_dataset(DATA_ROOT, SAMPLES)

    loaders, datasets = get_dataloaders(DATA_ROOT, BATCH_SIZE)

    # ── Class weights for Focal Loss ──────────────────────────────────────────
    class_weights = datasets["train"].get_class_weights()
    print(f"\n[INFO] Class weights: { {c: f'{w:.3f}' for c, w in zip(CLASS_NAMES, class_weights)} }")

    # ── Build model ───────────────────────────────────────────────────────────
    model = MedicalResNet50(NUM_CLASSES, DROPOUT).to(DEVICE)
    model.register_hooks()   # Required for Grad-CAM

    total     = sum(p.numel() for p in model.parameters())
    trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)
    print(f"\n[MODEL] ResNet50 + SE block + custom head loaded")
    print(f"  Total params    : {total:,}")
    print(f"  Phase 1 trainable: {trainable:,} ({100*trainable/total:.1f}%)")

    criterion = FocalLoss(gamma=FOCAL_GAMMA, alpha=class_weights)

    # ── Phase 1: Feature Extraction ───────────────────────────────────────────
    opt1   = optim.Adam(filter(lambda p: p.requires_grad, model.parameters()),
                        lr=P1_LR, weight_decay=WEIGHT_DECAY)
    sched1 = optim.lr_scheduler.ReduceLROnPlateau(opt1, patience=3, factor=0.5, verbose=False)

    h1 = run_phase(model, loaders, criterion, opt1, sched1, DEVICE,
                   P1_EPOCHS, "Phase 1: Feature Extraction (backbone frozen)")

    # ── Phase 2: Full Fine-Tuning ─────────────────────────────────────────────
    print(f"\n[INFO] Unfreezing top ResNet blocks ...")
    model.unfreeze_top_layers(num_blocks=2)

    opt2 = optim.AdamW([
        {"params": model.features[-2].parameters(), "lr": P2_LR * 0.1},   # layer3
        {"params": model.features[-1].parameters(), "lr": P2_LR * 0.5},   # layer4
        {"params": model.se_block.parameters(),     "lr": P2_LR},
        {"params": model.classifier.parameters(),   "lr": P2_LR},
    ], weight_decay=WEIGHT_DECAY)
    sched2 = optim.lr_scheduler.CosineAnnealingLR(opt2, T_max=P2_EPOCHS, eta_min=1e-6)

    h2 = run_phase(model, loaders, criterion, opt2, sched2, DEVICE,
                   P2_EPOCHS, "Phase 2: Full Fine-Tuning (differential LR)")

    # ── Final Evaluation ──────────────────────────────────────────────────────
    print(f"\n{'━'*62}")
    print(f"  FINAL TEST SET EVALUATION")
    print(f"{'━'*62}")
    _, acc, preds, labels, probs = evaluate(model, loaders["test"], criterion, DEVICE)
    print(f"  Test Accuracy : {acc:.4f}  ({acc*100:.2f}%)\n")
    print(classification_report(labels, preds, target_names=CLASS_NAMES, digits=4))

    # AUC-ROC
    try:
        aucs = {c: roc_auc_score(
            label_binarize(labels, classes=range(NUM_CLASSES))[:, i], probs[:, i]
        ) for i, c in enumerate(CLASS_NAMES)}
        print("  AUC-ROC per class:")
        for c, a in aucs.items():
            print(f"    {c:<15} {a:.4f}")
    except Exception:
        pass

    # ── Save model checkpoint ─────────────────────────────────────────────────
    ckpt_path = os.path.join(OUTPUT_DIR, "resnet50_xray_classifier.pth")
    torch.save({
        "model_state_dict": model.state_dict(),
        "class_names":      CLASS_NAMES,
        "test_accuracy":    acc,
        "phase1_history":   h1,
        "phase2_history":   h2,
    }, ckpt_path)
    print(f"\n  Model saved → {ckpt_path}")

    # ── Generate all plots ────────────────────────────────────────────────────
    print("\n[PLOTS] Generating visualisations ...")
    plot_class_distribution(DATA_ROOT,
        os.path.join(OUTPUT_DIR, "1_class_distribution.png"))
    plot_training_curves(h1, h2,
        os.path.join(OUTPUT_DIR, "2_training_curves.png"))
    plot_confusion_matrix(labels, preds,
        os.path.join(OUTPUT_DIR, "3_confusion_matrix.png"))
    plot_roc_curves(labels, probs,
        os.path.join(OUTPUT_DIR, "4_roc_curves.png"))
    plot_per_class_sensitivity(labels, preds,
        os.path.join(OUTPUT_DIR, "5_sensitivity_chart.png"))
    plot_gradcam_grid(model, datasets["test"], DEVICE,
        os.path.join(OUTPUT_DIR, "6_gradcam_visualisations.png"))

    print(f"\n✅  All outputs saved to ./{OUTPUT_DIR}/")
    print(f"{'═'*62}")


if __name__ == "__main__":
    main()
