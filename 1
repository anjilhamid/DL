    },
    "COVID-19": {
        "base_brightness": 120,
        "lung_opacity":    0.5,   # bilateral ground-glass opacities
        "infiltrate":      True,
        "consolidation":   False,
        "nodules":         0,
    },
    "Tuberculosis": {
        "base_brightness": 140,
